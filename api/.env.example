# Auth secrets — copy to .env and fill in real values
# Generate with: POST http://localhost:5050/auth/setup { "password": "yourpassword" }

Auth__Username=kcw
Auth__PasswordHash=             # bcrypt hash from /auth/setup
Auth__TotpSecret=               # base32 secret from /auth/setup (scan QR with authenticator)
Auth__JwtSecret=                # random 256-bit key: openssl rand -base64 32

# CORS origin for production
AllowedOrigin=https://your-domain.com
